{
  "shopper_flow": {
    "feature": "E2E Shopper Flow — Browse › Store › Product › Bag › Checkout › Place Order",
    "total_steps": 8,
    "environments": {
      "staging": {
        "app_package": "live.hoods.staging",
        "app_activity": ".MainActivity",
        "vars": {
          "store_desc": "jim_perfume_store",
          "product_desc": "150"
        }
      },
      "production": {
        "app_package": "live.hoods",
        "app_activity": ".MainActivity",
        "vars": {
          "store_desc": "jim_perfume_store",
          "product_desc": "150"
        }
      }
    },
    "steps": [
      {
        "index": 1,
        "label": "Open Profile tab",
        "action": "tap_percent",
        "pre_delay_ms": 5000,
        "post_delay_ms": 3000,
        "value": { "x_pct": 0.875, "y_pct": 0.95 }
      },
      {
        "index": 2,
        "label": "Select store {{store_desc}}",
        "action": "click",
        "selector": { "type": "content_desc_contains", "value": "{{store_desc}}" },
        "timeout_ms": 20000,
        "post_delay_ms": 500
      },
      {
        "index": 3,
        "label": "Select product containing {{product_desc}}",
        "action": "click",
        "selector": { "type": "content_desc_contains", "value": "{{product_desc}}" },
        "timeout_ms": 20000,
        "post_delay_ms": 500
      },
      {
        "index": 4,
        "label": "Scroll to 'Add to bag' and tap",
        "action": "scroll_click",
        "selector": { "type": "content_desc_exact", "value": "Add to bag" },
        "max_scrolls": 6,
        "timeout_ms": 20000,
        "post_delay_ms": 2000
      },
      {
        "index": 5,
        "label": "Open Bag tab",
        "action": "tap_percent",
        "post_delay_ms": 3000,
        "value": { "x_pct": 0.625, "y_pct": 0.95 }
      },
      {
        "index": 6,
        "label": "Check out",
        "action": "click",
        "selector": { "type": "content_desc_contains", "value": "Check out" },
        "timeout_ms": 20000,
        "post_delay_ms": 3000
      },
      {
        "index": 7,
        "label": "Place your order",
        "action": "click",
        "selector": { "type": "content_desc_exact", "value": "Place your order" },
        "timeout_ms": 20000,
        "post_delay_ms": 1000,
        "screenshot_before": "before_place_order",
        "screenshot_after": "after_place_order"
      },
      {
        "index": 8,
        "label": "Confirm order — poll 'Maybe later'",
        "action": "poll_confirm",
        "confirm_selector": { "type": "content_desc_exact", "value": "Maybe later" },
        "retap_selector": { "type": "content_desc_exact", "value": "Place your order" },
        "retap_on_trial": 2,
        "trials": 3,
        "poll_interval_ms": 3000,
        "order_id_selector": { "type": "content_desc_contains", "value": "Order Number" },
        "order_id_regex": "(\\d+)"
      }
    ]
  },
  "seller_flow": {
    "feature": "E2E Seller Flow — Upload Video › Select Product › Post",
    "total_steps": 9,
    "environments": {
      "staging": {
        "app_package": "live.hoods.seller.staging",
        "app_activity": "live.hoods.seller.staging.MainActivity",
        "vars": {
          "product_desc": "worldcup",
          "video_file_name": "AI Try",
          "video_title": "AI Try"
        }
      },
      "production": {
        "app_package": "live.hoods.seller",
        "app_activity": "live.hoods.seller.MainActivity",
        "vars": {
          "product_desc": "worldcup",
          "video_file_name": "AI Try",
          "video_title": "AI Try"
        }
      }
    },
    "steps": [
      {
        "index": 1,
        "label": "Tap the '+' Create icon",
        "action": "tap_percent",
        "pre_delay_ms": 3000,
        "post_delay_ms": 1000,
        "value": { "x_pct": 0.5, "y_pct": 0.95 }
      },
      {
        "index": 2,
        "label": "Tap 'Upload a Video'",
        "action": "click",
        "selector": { "type": "content_desc_exact", "value": "Upload a Video" },
        "timeout_ms": 20000,
        "post_delay_ms": 1500
      },
      {
        "index": 3,
        "label": "Select video '{{video_file_name}}' in file picker",
        "action": "pick_file",
        "selector": { "type": "text_contains", "value": "{{video_file_name}}" },
        "fallback_resource_id": "com.android.documentsui:id/icon_thumb",
        "fallback_tap_percent": { "x_pct": 0.26, "y_pct": 0.60 },
        "timeout_ms": 15000,
        "post_delay_ms": 1500
      },
      {
        "index": 4,
        "label": "Enter video title",
        "action": "type_text",
        "selector": { "type": "class_name", "value": "android.widget.EditText" },
        "text": "{{video_title}}",
        "timeout_ms": 15000,
        "post_delay_ms": 500
      },
      {
        "index": 5,
        "label": "Tap 'Select Products'",
        "action": "click",
        "selector": { "type": "content_desc_exact", "value": "Select Products" },
        "timeout_ms": 15000,
        "post_delay_ms": 1000
      },
      {
        "index": 6,
        "label": "Select product containing {{product_desc}}",
        "action": "scroll_click",
        "selector": { "type": "text_contains", "value": "{{product_desc}}" },
        "max_scrolls": 6,
        "timeout_ms": 15000,
        "post_delay_ms": 500
      },
      {
        "index": 7,
        "label": "Confirm product selection ('Ok')",
        "action": "click",
        "selector": { "type": "content_desc_exact", "value": "Ok" },
        "timeout_ms": 15000,
        "post_delay_ms": 500
      },
      {
        "index": 8,
        "label": "Tap 'Post Video'",
        "action": "click",
        "selector": { "type": "content_desc_exact", "value": "Post Video" },
        "timeout_ms": 15000,
        "post_delay_ms": 700
      },
      {
        "index": 9,
        "label": "Wait for video upload to finish (no error)",
        "action": "poll_no_error",
        "error_selectors": [
          { "type": "content_desc_contains", "value": "error" },
          { "type": "content_desc_contains", "value": "close_icon" },
          { "type": "text_contains", "value": "error" },
          { "type": "text_contains", "value": "Error" },
          { "type": "text_contains", "value": "failed" }
        ],
        "trials": 12,
        "poll_interval_ms": 10000
      }
    ]
  }
}
